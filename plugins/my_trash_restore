#!/usr/bin/env bash
# my_trash_restore - fuzzy-restore trashed files using trash-cli's own
# `trash-restore`, so restoring is 100% consistent with how trashing was done
# (correct .trashinfo cleanup, all trash cans, no manual inode/mv juggling).
#
# How it works:
#   1. Ask `trash-restore` for its canonical, indexed candidate list (feeding
#      empty input so it prints the menu and restores nothing).
#   2. Let you fuzzy-pick one or many lines in fzf. Each line carries the exact
#      index `trash-restore` assigned to it (field 1), so duplicates of the same
#      path at different deletion times stay unambiguous.
#   3. Feed the chosen indices back to a single `trash-restore` run as a
#      comma-separated list (supported since trash-cli ~0.22+).
#
# Requires: trash-cli (>= ~0.22, tested on 0.24.x), fzf.
# Install:  ~/.config/nnn/plugins/my_trash_restore  (chmod +x);
#           NNN_PLUG entry `r:my_trash_restore`; invoke inside nnn with  ;r

set -u

# Scope of the candidate list, used IDENTICALLY for listing and restoring so
# the indices match. "/" = whole trash can. Use "." for current-dir subtree only.
FILTER="/"
# Sort order must also match between the two trash-restore calls.
SORT="date"

pause() { printf '\n%s' 'Press any key to continue...'; read -r _ </dev/tty; }

for c in trash-restore fzf; do
    command -v "$c" >/dev/null 2>&1 || { echo "$c not found in PATH."; pause; exit 1; }
done

# 1. Canonical indexed menu, exactly as trash-restore numbers it. Empty stdin
#    makes it print the list and restore nothing. Keep only "<idx> <date> <path>".
menu=$(printf '\n' | trash-restore --sort="$SORT" "$FILTER" 2>/dev/null \
        | grep -E '^[[:space:]]*[0-9]+[[:space:]]')

if [ -z "$menu" ]; then
    echo "Trash is empty (nothing to restore)."
    pause
    exit 0
fi

# 2. Fuzzy-pick. Field 1 of each line is the index trash-restore will accept.
chosen=$(printf '%s\n' "$menu" | fzf \
    --multi \
    --prompt='restore > ' \
    --header=$'TAB: multi-select   ENTER: restore   ESC: cancel' \
    --preview='printf %s {}' \
    --preview-window=down,2,wrap) || exit 0

[ -z "$chosen" ] && exit 0

# 3. Indices -> comma list -> one trash-restore run (same FILTER/SORT => same
#    numbering as the menu we just showed).
indices=$(printf '%s\n' "$chosen" | awk '{printf "%s%s", sep, $1; sep=","} END{print ""}')

echo "Asking trash-restore to restore index(es): $indices"
echo
out=$(printf '%s\n' "$indices" | trash-restore --sort="$SORT" "$FILTER" 2>&1)
rc=$?
[ -n "$out" ] && printf '%s\n' "$out"

if [ "$rc" -ne 0 ] || printf '%s' "$out" | grep -qi 'refusing to overwrite'; then
    echo
    echo "Note: items whose original path already exists were NOT restored"
    echo "(trash-restore refuses to overwrite by default)."
    echo "To force-overwrite a specific one:  trash-restore --overwrite <path>"
fi

pause
